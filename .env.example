# Copy this file to .env before running local commands.
# Keep passwords URL encoded when embedded in URLs.

# Frontend/Gateway
FRONTEND_PORT=5173
GATEWAY_PORT=3000
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000
GATEWAY_QUEUE_NAME=cloudrag-jobs
GATEWAY_QUERY_TIMEOUT_MS=15000

# Redis (queue + semantic cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=cloudrag_redis_pw_change_me
REDIS_URL=redis://:cloudrag_redis_pw_change_me@localhost:6379/0

# Worker runtime
WORKER_RUNTIME_BACKEND=services
CHUNK_SIZE=800
CHUNK_OVERLAP=120
DENSE_VECTOR_DIMENSIONS=1536
SPARSE_VECTOR_DIMENSIONS=2048
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.92

# PostgreSQL (local metadata/state)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag
POSTGRES_PASSWORD=cloudrag_postgres_pw_change_me
POSTGRES_URL=postgresql://cloudrag:cloudrag_postgres_pw_change_me@localhost:5432/cloudrag

# MinIO (S3-compatible object storage)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=cloudrag-admin
MINIO_ROOT_PASSWORD=cloudrag_minio_pw_change_me
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=cloudrag-admin
S3_SECRET_ACCESS_KEY=cloudrag_minio_pw_change_me
S3_BUCKET_RAW_DOCUMENTS=cloudrag-raw-documents

# Qdrant (vector database)
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=cloudrag_qdrant_api_key_change_me
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cloudrag-documents

# Model/runtime knobs
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
EMBEDDING_BATCH_SIZE=64
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
LLM_API_BASE_URL=
PROMPT_TEMPLATE_VERSION=2026-05-12
OTEL_SERVICE_NAME=cloudrag-local
OTEL_SDK_DISABLED=false
